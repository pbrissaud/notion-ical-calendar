{
	"name": "notion-ical-calendar",
	"version": "1.0.0",
	"description": "Node.js application that connects to a Notion database and exposes calendar events as an iCal feed",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"dev": "dotenv -- tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"notion",
		"ical",
		"calendar",
		"ics"
	],
	"author": "",
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@notionhq/client": "^5.0.0",
		"ical-generator": "^10.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "^25.6.0",
		"dotenv-cli": "^11.0.0",
		"tsx": "^4.19.2",
		"typescript": "^6.0.0",
		"vite": "^8.0.8",
		"vitest": "^4.0.0"
	}
}
