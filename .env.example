# Required
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret token to protect the calendar feed URL.
# Generate with: openssl rand -hex 32
# When set, the feed is served at /calendar/<TOKEN>.ics
# When unset, the feed is public at /calendar.ics (not recommended in production)
CALENDAR_TOKEN=

# Optional — defaults shown
PORT=3000
CACHE_TTL=300

# Notion property name overrides (only needed if your DB uses different names)
# NOTION_PROPERTY_TITLE=Name
# NOTION_PROPERTY_DATE=Date
# NOTION_PROPERTY_DESCRIPTION=
# NOTION_PROPERTY_LOCATION=
